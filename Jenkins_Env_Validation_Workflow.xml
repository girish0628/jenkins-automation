<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="app.diagrams.net">
  <diagram name="Jenkins Environment Validation Workflow">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1"
      tooltips="1" connect="1" arrows="1" fold="1"
      page="1" pageScale="1" pageWidth="1600" pageHeight="1200">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Start -->
        <mxCell id="start" value="Start validator.py"
          style="ellipse;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;"
          vertex="1" parent="1">
          <mxGeometry x="600" y="40" width="280" height="60" as="geometry"/>
        </mxCell>

        <!-- Load Config -->
        <mxCell id="config" value="Load config.json
Environment | Nodes | Labels
SDE | Jenkins | GitLab"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;"
          vertex="1" parent="1">
          <mxGeometry x="540" y="140" width="400" height="90" as="geometry"/>
        </mxCell>

        <!-- Parallel -->
        <mxCell id="parallel" value="Execute Validation Checks
Parallel Execution Enabled
Continue on Failure"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;"
          vertex="1" parent="1">
          <mxGeometry x="540" y="270" width="400" height="90" as="geometry"/>
        </mxCell>

        <!-- Env Checks -->
        <mxCell id="env" value="Environment Validation
Env Variables
ArcPy License
Disk Space
Installed Software"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;"
          vertex="1" parent="1">
          <mxGeometry x="100" y="420" width="350" height="140" as="geometry"/>
        </mxCell>

        <!-- Network -->
        <mxCell id="network" value="Network Validation
Network Share RW
SDE Read Only Test"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;"
          vertex="1" parent="1">
          <mxGeometry x="520" y="420" width="350" height="120" as="geometry"/>
        </mxCell>

        <!-- Jenkins -->
        <mxCell id="jenkins" value="Jenkins Validation
Agents Online
Label Verification
Trigger Test Job
Job Chaining
Email Verification"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;"
          vertex="1" parent="1">
          <mxGeometry x="940" y="420" width="350" height="160" as="geometry"/>
        </mxCell>

        <!-- GitLab -->
        <mxCell id="gitlab" value="SCM Security
GitLab PAT Validation"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;"
          vertex="1" parent="1">
          <mxGeometry x="520" y="600" width="350" height="80" as="geometry"/>
        </mxCell>

        <!-- Report -->
        <mxCell id="report" value="Generate JSON Report
reports/jenkins_env_report_NODE_ENV.json"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;"
          vertex="1" parent="1">
          <mxGeometry x="540" y="720" width="400" height="100" as="geometry"/>
        </mxCell>

        <!-- End -->
        <mxCell id="end" value="Validation Complete
Exit Code 0 or 2"
          style="ellipse;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;"
          vertex="1" parent="1">
          <mxGeometry x="600" y="860" width="280" height="60" as="geometry"/>
        </mxCell>

        <!-- Connectors -->
        <mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;"
          edge="1" parent="1" source="start" target="config">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e2" style="edgeStyle=orthogonalEdgeStyle;"
          edge="1" parent="1" source="config" target="parallel">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e3" style="edgeStyle=orthogonalEdgeStyle;"
          edge="1" parent="1" source="parallel" target="env">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e4" style="edgeStyle=orthogonalEdgeStyle;"
          edge="1" parent="1" source="parallel" target="network">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e5" style="edgeStyle=orthogonalEdgeStyle;"
          edge="1" parent="1" source="parallel" target="jenkins">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e6" style="edgeStyle=orthogonalEdgeStyle;"
          edge="1" parent="1" source="network" target="gitlab">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e7" style="edgeStyle=orthogonalEdgeStyle;"
          edge="1" parent="1" source="gitlab" target="report">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e8" style="edgeStyle=orthogonalEdgeStyle;"
          edge="1" parent="1" source="report" target="end">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>